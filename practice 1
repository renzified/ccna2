1. configure c1/c2 as dhcp servers for p1/p2
c1: 10.2.1.100 - 10.2.1.199
c2: 10.2.1.200 - 10.2.1.254

!@c1
config t
    ip dhcp excluded-add 10.2.1.1 10.2.1.99
    ip dhcp excluded-add 10.2.1.200 10.2.1.254
    ip dhcp pool MGMTPOOL
        network         10.2.1.0 255.255.255.0
        default-router  10.2.1.1
        dns-servers     10.2.1.1
        domain-name     MGMT.COM
end

!@c2
config t
    ip dhcp excluded-add 10.2.1.1 10.2.1.199
    ip dhcp pool MGMTPOOL
        network         10.2.1.0 255.255.255.0
        default-router  10.2.1.2
        dns-servers     10.2.1.2
        domain-name     MGMT.COM
end

!@A1
config t
    int e0/0
    switchport mode access
    switchport access vlan 10
end

!@P1
config t
    int e0/0
    no shut
    ip add dhcp
end

!@P2
config t
    int e1/0
    no shut
    ip add dhcp
end