sr = sh run
ss = sh start
crs = copy run start
siib = sh ip int brief
svb = sh vlan brief
sit = sh int trunk
smac = sh mac address-table
sir = sh ip route
scn = sh cdp neighbor


!sets the dns server of the component
conf t
 ip domain lookup
 ip name-server 10.m.1.8
end

! gets the ip address of the hayup activity
rm -rf /etc/udev/rules.d/70-persistent-net.rules
reboot

! configure to be a dhcp server

!d1
conf t
 ip dhcp excluded-add 10.2.1.1 10.2.1.99
 ip dhcp excluded-add 10.2.1.200 10.2.1.254
 ip dhcp pool MGMTPOOL
  network         10.2.1.0  255.255.255.0
  default-router  10.2.1.1
  dns-server      10.2.1.1
  domain-name     MGMT.COM
end

!d2
conf t
 ip dhcp excluded-add 10.2.1.1 10.2.1.199
 ip dhcp pool MGMTPOOL
  network         10.2.1.0  255.255.255.0
  default-router  10.2.1.2
  dns-server      10.2.1.2
  domain-name     MGMT.COM
end

! by default vlan assignment is vlan 1 so lets move it to vlan 10

!a1
conf t
 int e0/0
  switchport mode access
  switchport access vlan 10
end

!a2
conf t
 int e1/0
  switchport mode access
  switchport access vlan 10
  end

! configure as dhcp client

!p1
conf t
 int e0/0
  no shut
  ip add dhcp
end

!p2
conf t
 int e1/0
  no shut
  ip add dhcp
  end

